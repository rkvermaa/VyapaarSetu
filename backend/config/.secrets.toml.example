# Secrets - DO NOT COMMIT to git!
# Copy this file to .secrets.toml and fill in your values.

[default]
# Database
database_url = "postgresql+asyncpg://postgres:postgres@localhost:5432/vyapaarsetu"

# Redis
redis_url = "redis://localhost:6379/0"

# JWT Secret
jwt_secret_key = "change-this-to-a-random-secret-string"

# DeepSeek API
deepseek_api_key = ""
deepseek_base_url = "https://api.deepseek.com"

# Sarvam AI (TTS + STT — for future voice processing)
sarvam_api_key = ""

[production]
database_url = "@format {env[DATABASE_URL]}"
redis_url = "@format {env[REDIS_URL]}"
jwt_secret_key = "@format {env[JWT_SECRET_KEY]}"
deepseek_api_key = "@format {env[DEEPSEEK_API_KEY]}"
